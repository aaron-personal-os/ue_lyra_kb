---
// src/components/layout/ThemeToggle.astro
//
// 亮/暗主题切换按钮。
//
// 状态层级：
//   localStorage('lyra-kb-theme') → <html data-theme="..."> → CSS 变量切换
//
// 防 FOUC：BaseLayout.astro 的 pre-paint inline script 已在首帧之前
//          根据 localStorage / prefers-color-scheme 设好 data-theme，
//          这里只需在用户交互时翻转、并广播 `theme-change` 事件给
//          需要响应的 React Island（如 Mermaid）。
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle shrink-0 p-2 rounded-md text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-2)] transition-colors"
  aria-label="切换亮色 / 暗色主题"
  title="切换亮色 / 暗色主题（T）"
>
  <!-- Sun icon (visible in dark theme — clicking switches TO light) -->
  <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>

  <!-- Moon icon (visible in light theme — clicking switches TO dark) -->
  <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<style>
  /* Show only the icon that represents the *opposite* of the current theme,
     so the user reads it as "click to switch to that mode". */
  :global(html[data-theme="dark"]) .theme-toggle .icon-moon { display: none; }
  :global(html[data-theme="light"]) .theme-toggle .icon-sun { display: none; }
  /* Default (no attribute yet) — show sun, behave like dark */
  :global(html:not([data-theme])) .theme-toggle .icon-moon { display: none; }
</style>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'lyra-kb-theme';
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function currentTheme() {
      return document.documentElement.getAttribute('data-theme') || 'dark';
    }

    function applyTheme(next) {
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem(STORAGE_KEY, next); } catch (e) {}
      // Broadcast so other listeners (Mermaid, etc.) can react.
      window.dispatchEvent(new CustomEvent('theme-change', { detail: { theme: next } }));
    }

    function toggle() {
      applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
    }

    btn.addEventListener('click', toggle);

    // Keyboard shortcut: T (when not typing in an input/textarea/contenteditable)
    document.addEventListener('keydown', function (ev) {
      if (ev.key !== 't' && ev.key !== 'T') return;
      if (ev.ctrlKey || ev.metaKey || ev.altKey) return;
      var t = ev.target;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      toggle();
    });
  })();
</script>
