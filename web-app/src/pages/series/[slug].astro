---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Badge from '@/components/ui/Badge.astro';
import { getAllSeries, getSeriesBySlug, getLessonMeta } from '@/lib/series';
import { getSeriesTheme } from '@/lib/theme';

export function getStaticPaths() {
  const allSeries = getAllSeries();
  return allSeries.map((series) => ({
    params: { slug: series.slug },
  }));
}

const { slug } = Astro.params;
const series = getSeriesBySlug(slug!);

if (!series) {
  return Astro.redirect('/404');
}

const theme = getSeriesTheme(slug!);

// Pre-compute lesson metadata so we don't repeat fs reads in templates
const stagesWithMeta = series.learning_path.map((stage) => ({
  ...stage,
  lessonMetas: stage.lessons.map((lesson) => ({
    file: lesson,
    ...getLessonMeta(slug!, lesson),
  })),
}));

const totalLessonsResolved =
  series.total_lessons || stagesWithMeta.reduce((sum, s) => sum + s.lessonMetas.length, 0);

const difficultyDisplay = Array.isArray(series.difficulty_range)
  ? series.difficulty_range.join(' → ')
  : series.difficulty_range || '';
---

<BaseLayout title={series.name} description={series.description}>
  <Navbar />

  <main>
    <!-- Hero (full viewport) -->
    <section
      class="series-hero relative flex flex-col items-center justify-center overflow-hidden"
      style={`--series-accent: ${theme.accent};`}
    >
      <!-- Themed gradient backdrop -->
      <div class={`absolute inset-0 bg-gradient-to-br ${theme.gradient} opacity-95`}></div>

      <!-- Soft accent glow blobs -->
      <div class="hero-blob hero-blob--a"></div>
      <div class="hero-blob hero-blob--b"></div>
      <div class="hero-blob hero-blob--c"></div>

      <!-- Subtle grid overlay for tech feel -->
      <div class="absolute inset-0 hero-grid pointer-events-none"></div>

      <!-- Top-to-bottom fade into page background, removes the abrupt edge -->
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-[var(--surface-0)]"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <!-- Series badge -->
        <div class="flex items-center justify-center gap-2 mb-5">
          <span
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono font-semibold uppercase tracking-wider backdrop-blur-sm"
            style="background: rgba(255,255,255,0.10); color: var(--series-accent); border: 1px solid color-mix(in srgb, var(--series-accent) 45%, transparent);"
          >
            <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: var(--series-accent);"></span>
            Series · {slug}
          </span>
          {difficultyDisplay && (
            <Badge variant="default" size="sm">
              <span class="text-white/85">{difficultyDisplay}</span>
            </Badge>
          )}
        </div>

        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight leading-[1.15] drop-shadow-[0_4px_18px_rgba(0,0,0,0.4)]">
          {series.name}
        </h1>

        {series.description && (
          <p class="mt-5 text-base md:text-lg text-white/75 max-w-2xl mx-auto leading-relaxed">
            {series.description}
          </p>
        )}

        <!-- Quick meta -->
        <div class="flex flex-wrap items-center justify-center gap-3 mt-7">
          {series.ue_version && (
            <span class="hero-meta">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              UE {series.ue_version}
            </span>
          )}
          {!!series.estimated_hours && (
            <span class="hero-meta">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              ~{series.estimated_hours} hours
            </span>
          )}
          {!!totalLessonsResolved && (
            <span class="hero-meta">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              {totalLessonsResolved} lessons
            </span>
          )}
        </div>

        <!-- CTA -->
        {stagesWithMeta[0]?.lessonMetas[0] && (
          <div class="mt-9 flex items-center justify-center gap-3">
            <a
              href={`/series/${slug}/${stagesWithMeta[0].lessonMetas[0].file}`}
              class="hero-cta hero-cta--primary"
            >
              开始学习
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
            <a href="#learning-path" class="hero-cta hero-cta--ghost">
              查看路径
            </a>
          </div>
        )}
      </div>

      <!-- Scroll indicator -->
      <a
        href="#learning-path"
        class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/55 hover:text-white transition-colors"
        aria-label="Scroll to learning path"
      >
        <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </section>

    <!-- Page content -->
    <div class="max-w-5xl mx-auto px-6 pb-24 pt-2">
      <!-- Learning Path -->
      <section id="learning-path" class="path-section scroll-reveal pt-14">
        <div class="mb-10 text-center">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono font-semibold uppercase tracking-wider mb-3"
               style="background: color-mix(in srgb, var(--series-accent) 12%, transparent); color: var(--series-accent); border: 1px solid color-mix(in srgb, var(--series-accent) 30%, transparent);">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 9 12 3 18"/><polyline points="21 6 15 12 21 18"/></svg>
            Learning Path
          </div>
          <h2 class="text-3xl font-bold text-[var(--text-primary)] tracking-tight">学习路径</h2>
          <p class="mt-2 text-sm text-[var(--text-secondary)]">按以下路径循序渐进，系统掌握核心知识</p>
        </div>

        <div class="path-timeline" style={`--series-accent: ${theme.accent};`}>
          {stagesWithMeta.map((stage, stageIdx) => (
            <div class="path-stage">
              <!-- Stage marker (number bubble) -->
              <div class="path-stage__marker">
                <span class="path-stage__num">{String(stageIdx + 1).padStart(2, '0')}</span>
              </div>

              <!-- Stage content -->
              <div class="path-stage__content">
                <header class="path-stage__header">
                  <h3 class="path-stage__title">{stage.stage}</h3>
                  {stage.description && (
                    <p class="path-stage__desc">{stage.description}</p>
                  )}
                </header>

                <ul class="path-stage__lessons">
                  {stage.lessonMetas.map((lesson, lessonIdx) => (
                    <li>
                      <a
                        href={`/series/${slug}/${lesson.file}`}
                        class="lesson-card"
                        style={`--series-accent: ${theme.accent};`}
                      >
                        <span class="lesson-card__index">
                          {String(lessonIdx + 1).padStart(2, '0')}
                        </span>
                        <div class="lesson-card__main">
                          <div class="lesson-card__title">{lesson.title}</div>
                          {lesson.summary && (
                            <div class="lesson-card__summary">{lesson.summary}</div>
                          )}
                          <div class="lesson-card__meta">
                            {lesson.difficulty && (
                              <span class="lesson-card__chip">{lesson.difficulty}</span>
                            )}
                            {lesson.estimatedMinutes !== undefined && (
                              <span class="lesson-card__chip">~{lesson.estimatedMinutes} min</span>
                            )}
                          </div>
                        </div>
                        <span class="lesson-card__arrow" aria-hidden="true">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Tags -->
      {series.tags && series.tags.length > 0 && (
        <section class="mt-16 pt-6 border-t border-[var(--border)]">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-sm text-[var(--text-secondary)] mr-2">Tags:</span>
            {series.tags.map((tag) => (
              <span class={`px-2 py-0.5 rounded text-xs ${theme.badge}`}>
                {tag}
              </span>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <style>
    /* ---------------- Hero ---------------- */
    .series-hero {
      min-height: 100vh;
      isolation: isolate;
    }

    .hero-grid {
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
      mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7) 0%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.7) 0%, transparent 70%);
    }

    .hero-blob {
      position: absolute;
      border-radius: 9999px;
      filter: blur(80px);
      opacity: 0.55;
      pointer-events: none;
    }
    .hero-blob--a {
      top: -10%;
      left: 8%;
      width: 32rem;
      height: 32rem;
      background: color-mix(in srgb, var(--series-accent) 35%, transparent);
    }
    .hero-blob--b {
      bottom: -15%;
      right: 5%;
      width: 28rem;
      height: 28rem;
      background: color-mix(in srgb, var(--series-accent) 25%, transparent);
    }
    .hero-blob--c {
      top: 30%;
      right: 30%;
      width: 16rem;
      height: 16rem;
      background: rgba(255, 255, 255, 0.06);
    }

    .hero-meta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.8rem;
      border-radius: 999px;
      font-size: 12.5px;
      color: rgba(255, 255, 255, 0.78);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.65rem 1.3rem;
      border-radius: 9999px;
      font-size: 14px;
      font-weight: 600;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    }
    .hero-cta--primary {
      color: #0f1117;
      background: var(--series-accent);
      box-shadow: 0 8px 24px -8px color-mix(in srgb, var(--series-accent) 60%, transparent);
    }
    .hero-cta--primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 28px -8px color-mix(in srgb, var(--series-accent) 75%, transparent);
    }
    .hero-cta--ghost {
      color: rgba(255, 255, 255, 0.85);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .hero-cta--ghost:hover {
      background: rgba(255, 255, 255, 0.14);
    }

    /* ---------------- Learning Path Timeline ---------------- */
    .path-timeline {
      position: relative;
      padding-left: 0;
    }

    .path-stage {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 1.25rem;
      position: relative;
      padding-bottom: 2.75rem;
    }

    /* Vertical connector line in the marker column */
    .path-stage::before {
      content: '';
      position: absolute;
      left: 31px;
      top: 56px;
      bottom: 0;
      width: 2px;
      background: linear-gradient(
        to bottom,
        color-mix(in srgb, var(--series-accent) 55%, transparent),
        color-mix(in srgb, var(--series-accent) 12%, transparent) 70%,
        transparent
      );
    }
    .path-stage:last-child::before {
      display: none;
    }

    .path-stage__marker {
      position: relative;
      width: 64px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .path-stage__marker::before {
      content: '';
      position: absolute;
      inset: 6px;
      border-radius: 9999px;
      background: color-mix(in srgb, var(--series-accent) 18%, transparent);
      filter: blur(6px);
    }
    .path-stage__num {
      position: relative;
      z-index: 1;
      width: 44px;
      height: 44px;
      border-radius: 9999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 13px;
      font-weight: 700;
      color: #0f1117;
      background: var(--series-accent);
      box-shadow:
        0 0 0 4px var(--surface-0),
        0 0 0 5px color-mix(in srgb, var(--series-accent) 40%, transparent),
        0 6px 18px -4px color-mix(in srgb, var(--series-accent) 50%, transparent);
    }

    .path-stage__header {
      margin-bottom: 1rem;
      padding-top: 0.4rem;
    }
    .path-stage__title {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.01em;
      line-height: 1.3;
    }
    .path-stage__desc {
      margin-top: 0.35rem;
      font-size: 13.5px;
      color: var(--text-secondary);
      line-height: 1.65;
    }

    .path-stage__lessons {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    /* ---------------- Lesson Card ---------------- */
    .lesson-card {
      display: grid;
      grid-template-columns: 44px 1fr 24px;
      align-items: center;
      gap: 1rem;
      padding: 0.85rem 1rem;
      border-radius: 12px;
      background: var(--surface-1);
      border: 1px solid var(--border);
      text-decoration: none;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
      position: relative;
      overflow: hidden;
    }
    .lesson-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--series-accent);
      opacity: 0;
      transition: opacity 0.18s ease;
    }
    .lesson-card:hover {
      transform: translateX(4px);
      border-color: color-mix(in srgb, var(--series-accent) 45%, var(--border));
      background: color-mix(in srgb, var(--series-accent) 4%, var(--surface-1));
      box-shadow: 0 8px 24px -12px color-mix(in srgb, var(--series-accent) 50%, transparent);
    }
    .lesson-card:hover::before {
      opacity: 1;
    }

    .lesson-card__index {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: color-mix(in srgb, var(--series-accent) 12%, transparent);
      color: color-mix(in srgb, var(--series-accent) 90%, white);
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 12.5px;
      font-weight: 700;
      letter-spacing: 0.04em;
      border: 1px solid color-mix(in srgb, var(--series-accent) 25%, transparent);
    }

    .lesson-card__main {
      min-width: 0;
    }
    .lesson-card__title {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.4;
      letter-spacing: -0.005em;
    }
    .lesson-card__summary {
      margin-top: 0.25rem;
      font-size: 12.5px;
      color: var(--text-secondary);
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .lesson-card__meta {
      margin-top: 0.4rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .lesson-card__chip {
      display: inline-flex;
      align-items: center;
      padding: 1px 8px;
      border-radius: 999px;
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 0.02em;
      color: var(--text-secondary);
      background: var(--surface-2);
      border: 1px solid var(--border);
    }

    .lesson-card__arrow {
      color: var(--text-secondary);
      opacity: 0.5;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.18s ease, opacity 0.18s ease, color 0.18s ease;
    }
    .lesson-card:hover .lesson-card__arrow {
      opacity: 1;
      color: var(--series-accent);
      transform: translateX(2px);
    }

    @media (max-width: 640px) {
      .path-stage {
        grid-template-columns: 48px 1fr;
        gap: 0.85rem;
      }
      .path-stage::before {
        left: 23px;
      }
      .path-stage__marker {
        width: 48px;
      }
      .path-stage__num {
        width: 36px;
        height: 36px;
        font-size: 12px;
      }
      .lesson-card {
        grid-template-columns: 36px 1fr 20px;
        gap: 0.7rem;
        padding: 0.7rem 0.85rem;
      }
      .lesson-card__index {
        width: 30px;
        height: 30px;
      }
    }
  </style>
</BaseLayout>
